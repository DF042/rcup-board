# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key — only used server-side (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Database (Drizzle / direct Postgres) ─────────────────────────────────────
# Connection string for Drizzle ORM (postgres package).
# For Supabase: use the "Transaction" or "Session" pooler URL from
#   Supabase project → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── OpenAI (AI Chat panel) ────────────────────────────────────────────────────
# Required for the /api/chat endpoint.  Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the default model (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o

# ── Next.js ───────────────────────────────────────────────────────────────────
# Set to your production domain when deploying (used for OAuth redirect URLs).
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
